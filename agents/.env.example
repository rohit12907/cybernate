# AlienVault OTX — Free tier: unlimited basic queries
# Sign up at https://otx.alienvault.com
OTX_API_KEY=your_otx_api_key_here

# Backend API (Person 1's FastAPI server)
BACKEND_API_URL=http://localhost:8000
