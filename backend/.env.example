# Backend Configuration
HOST=0.0.0.0
PORT=8000
DATABASE_PATH=cybermate.db

# Telegram Bot (get token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Gmail SMTP (use App Password, NOT your regular password)
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Agent API endpoint (Person 2 runs on this port)
AGENT_API_URL=http://localhost:8001

# Log file paths to watch (use demo_auth.log for the hackathon demo)
LOG_PATHS=demo_auth.log
